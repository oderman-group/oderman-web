# ODERMAN GROUP SAS - Configuración de URLs amigables y seguridad
# Habilitar mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /oderman-web/

    # Permitir acceso directo a archivos y directorios existentes
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Forzar HTTPS (descomentar cuando tengas SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Redirigir www a no-www (o viceversa según prefieras)
    # RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    # RewriteRule ^(.*)$ http://%1/$1 [R=301,L]

    # URLs amigables - Páginas de SINTIA (deben ir antes de las reglas generales)
    RewriteRule ^sintia/demo/?$ sintia-demo-colegios.php [L]
    RewriteRule ^sintia/demo-colegios/?$ sintia-demo-colegios.php [L]
    RewriteRule ^sintia/tarifas-comunicativo/?$ tarifas-modulo-comunicativo.php [L]
    RewriteRule ^sintia/ava/?$ ava-ambientes-virtuales.php [L]
    RewriteRule ^sintia/ambientes-virtuales/?$ ava-ambientes-virtuales.php [L]
    RewriteRule ^sintia/?$ index.php#productos [L]

    # URLs amigables - Páginas principales (si las creas en el futuro)
    RewriteRule ^about/?$ about.php [L]
    RewriteRule ^nosotros/?$ about.php [L]
    RewriteRule ^services/?$ services.php [L]
    RewriteRule ^servicios/?$ services.php [L]
    RewriteRule ^products/?$ products.php [L]
    RewriteRule ^productos/?$ products.php [L]
    RewriteRule ^contact/?$ contact.php [L]
    RewriteRule ^contacto/?$ contact.php [L]

    # Si el archivo .php existe, servir directamente
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]

    # Si es la raíz y no hay archivo específico, servir index.php
    RewriteRule ^$ index.php [L]
</IfModule>

# Seguridad y Headers
<IfModule mod_headers.c>
    # Prevenir clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # Prevenir MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (ajustar según necesidades)
    # Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-src https://www.youtube.com;"
</IfModule>

# Compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache de archivos estáticos
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/pdf "access plus 1 month"
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Prevenir listado de directorios
Options -Indexes

# Proteger archivos sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Charset UTF-8
AddDefaultCharset UTF-8

# Páginas de error personalizadas (opcional)
# ErrorDocument 404 /404.php
# ErrorDocument 500 /500.php
